  "confidence_routing": {
    "description": "Механизм определения, когда бот обязан направить пользователя к живому куратору.",
    "default_policy": "route_to_curator_if_uncertain",
    "score_calculation": {
      "factors": [
        {
          "name": "must_match_found",
          "weight": 1.0,
          "description": "Найден must-match кейс"
        },
        {
          "name": "faq_relevance",
          "weight": 0.7,
          "description": "Релевантность найденных FAQ (0.0-1.0)"
        },
        {
          "name": "tag_confidence",
          "weight": 0.6,
          "description": "Уверенность в выборе тега (0.0-1.0)"
        },
        {
          "name": "rule_clarity",
          "weight": 0.5,
          "description": "Четкость правила (0.0-1.0)"
        }
      ],
      "formula": "must_match_found * 1.0 + faq_relevance * 0.7 + tag_confidence * 0.6 + rule_clarity * 0.5"
    },
    "thresholds": {
      "auto_answer": 0.8,
      "clarification_required": 0.6,
      "route_to_curator": 0.0
    },
    "mandatory_escalation_triggers": [
